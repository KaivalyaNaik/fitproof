# Application
APP_ENV=development
APP_PORT=8080

# Database URL (used by golang-migrate and pgxpool)
# scheme must be pgx5:// for golang-migrate pgx/v5 driver
DATABASE_URL=pgx5://fitness_user:fitness_password@localhost:5432/fitness_challenge
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2

# JWT
JWT_SECRET=change_me_to_a_random_32_byte_hex_secret
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# Migrations
MIGRATIONS_PATH=./migrations

# Google OAuth
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI must match GOOGLE_CALLBACK_URL exactly
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
# In local dev, callback goes through the Next.js proxy (same origin → cookies work)
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Frontend base URL (used by backend to redirect after OAuth)
FRONTEND_URL=http://localhost:3000

# Email (SMTP) — leave SMTP_HOST empty to disable email sending (safe for local dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=FitProof <noreply@fitproof.app>
EMAIL_VERIFICATION_TTL=15m

# Cloudflare R2 (media storage — leave blank to disable uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Grafana Cloud Loki (centralised logs — leave GRAFANA_LOKI_URL empty to disable)
# URL: copy from Grafana Cloud Portal → your stack → Loki → Details → host
# Example: https://logs-prod-006.grafana.net (no trailing slash, no /loki/api/v1/push suffix)
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_TOKEN=
GRAFANA_LOKI_BATCH_INTERVAL=5s
GRAFANA_LOKI_BATCH_SIZE=100
