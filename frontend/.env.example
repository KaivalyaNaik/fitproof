BACKEND_URL=http://localhost:8080

# Grafana Cloud Loki — server-side only.
# NEVER prefix with NEXT_PUBLIC_ (would expose token to browser).
# URL: copy from Grafana Cloud Portal → your stack → Loki → Details → host
# Example: https://logs-prod-006.grafana.net (no trailing slash, no /loki/api/v1/push suffix)
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_TOKEN=
